# Ignore everything by default
*

# Unignore tracked files
!.gitignore
!README.md
!LICENSE
!criteria.md
!cv_tailoring_prompt.md
!igor_pivnyk_cv_base_updated.tex
!igor_pivnyk_cv_base_updated.pdf
!requirements.txt
# seen_jobs.json is NOT tracked on main — it lives on the orphan `state` branch.

# Unignore GitHub Actions workflow directory
!.github/
!.github/**

# Unignore the job_search package, the offline characterization suite, and the
# pytest config. Without these, a fresh clone / CI gets ModuleNotFoundError —
# the package files would stay invisible under the `*` default-ignore.
!job_search/
!job_search/**
!tests/
!tests/**
!pyproject.toml

# ...but never track Python bytecode or local scratch state, even though the
# allowlist above otherwise un-ignores everything under the package.
__pycache__/
*.pyc
job_state.json
.pytest_cache/
